{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genericscreengen.local/schemas/screen-config.schema.json",
  "title": "Generic Screen Configuration",
  "description": "Schema for dynamic screen configuration files used by GenericScreenGenApp.",
  "type": "object",
  "required": ["sections"],
  "properties": {
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/section"
      }
    }
  },
  "$defs": {
    "section": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "examples": ["default-section", "math-operations"]
        },
        "layout-policy": {
          "type": "string",
          "default": "per-line",
          "examples": ["per-line"]
        },
        "is-collapsible": {
          "type": "boolean",
          "default": true,
          "examples": [true, false]
        },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/field"
          }
        },
        "sections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/section"
          }
        }
      },
      "additionalProperties": false
    },
    "field": {
      "type": "object",
      "required": ["id", "name", "description", "type", "width"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "examples": ["calc-001", "ord-002"]
        },
        "name": {
          "type": "string",
          "examples": ["First Number", "Calculate"]
        },
        "description": {
          "type": "string",
          "examples": ["Type first number to add", "Click to compute the result"]
        },
        "type": {
          "type": "string",
          "enum": ["Integer", "Button", "Text"],
          "examples": ["Integer", "Button"]
        },
        "width": {
          "type": "string",
          "pattern": "^[0-9]+px$",
          "examples": ["300px", "200px"]
        }
      },
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "sections": [
        {
          "name": "default-section",
          "layout-policy": "per-line",
          "is-collapsible": false,
          "fields": [
            {
              "id": "calc-001",
              "name": "First Number",
              "description": "Type first number to add",
              "type": "Integer",
              "width": "300px"
            }
          ]
        }
      ]
    }
  ],
  "additionalProperties": false
}