{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genericscreengen.local/schemas/screen-config.schema.json",
  "title": "Generic Screen Configuration",
  "description": "Schema for dynamic screen configuration files used by GenericScreenGenApp.",
  "type": "object",
  "required": ["id", "name", "key", "sections", "features"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Mandatory screen identifier in kebab-case format.",
      "examples": ["employee-list", "calculator"]
    },
    "name": {
      "type": "string",
      "description": "Mandatory display name for the screen.",
      "examples": ["Employee List", "Calculator"]
    },
    "key": {
      "type": "array",
      "description": "Mandatory record key definition as a list of field identifiers. Use an empty array when no key is available yet.",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      },
      "examples": [[], ["emp-list-003"], ["ord-001", "ord-002"]]
    },
    "features": {
      "type": "array",
      "description": "Mandatory screen-level feature toggles. Use an empty array to disable all features. Supported values: 'save', 'cancel', 'show-original-values'.",
      "items": {
        "type": "string",
        "enum": ["save", "cancel", "show-original-values"]
      },
      "examples": [["save", "cancel", "show-original-values"], ["cancel"]]
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/section"
      }
    }
  },
  "$defs": {
    "section": {
      "type": "object",
      "required": ["name", "layout-policy", "is-collapsible"],
      "properties": {
        "name": {
          "type": "string",
          "examples": ["default-section", "math-operations"]
        },
        "layout-policy": {
          "type": "string",
          "description": "Mandatory. Controls how fields inside this section are arranged. Built-in values: 'per-line' (each field on its own line, vertical stack), 'flow' (fields flow left-to-right with wrap), and 'tabular' (fields are rendered as table columns with records as rows). New policies can be added by implementing ILayoutPolicy and registering the implementation in the dependency-injection container — no schema change required.",
          "examples": ["per-line", "flow", "tabular"]
        },
        "is-collapsible": {
          "type": "boolean",
          "description": "Mandatory. Whether the section can be collapsed by the user.",
          "examples": [true, false]
        },
        "selection-actions": {
          "type": "array",
          "description": "Selection action mappings for tabular sections. Use click and/or double-click to navigate to a target screen with record-id context.",
          "items": {
            "$ref": "#/$defs/selection-action"
          },
          "examples": [
            [
              {
                "event": "click",
                "target-screen-id": "screen-employee-detail",
                "include-record-id": true
              }
            ]
          ]
        },
        "fields": {
          "type": "array",
          "minItems": 1,
          "description": "When present, must contain at least one field definition.",
          "items": {
            "$ref": "#/$defs/field"
          }
        },
        "sections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/section"
          }
        }
      },
      "additionalProperties": false
    },
    "field": {
      "type": "object",
      "required": ["id", "name", "description", "type", "width"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "examples": ["calc-001", "ord-002"]
        },
        "name": {
          "type": "string",
          "examples": ["First Number", "Calculate"]
        },
        "description": {
          "type": "string",
          "examples": ["Type first number to add", "Click to compute the result"]
        },
        "type": {
          "type": "string",
          "enum": ["Integer", "Button", "Text", "Date", "DateTime", "Date-Time", "Lookup", "date", "date-time", "lookup", "text"],
          "examples": ["Integer", "Button", "Date", "date-time", "Lookup"]
        },
        "type-info": {
          "type": "string",
          "description": "Optional type-specific configuration. Text format: {min-chars=0;max-chars=10;lines=1;} Lookup format: {value 1;value 2;value 3}",
          "examples": ["{min-chars=0;max-chars=10;lines=1;}", "{Pending;Approved;Rejected}"]
        },
        "width": {
          "type": "string",
          "pattern": "^[0-9]+px$",
          "examples": ["300px", "200px"]
        },
        "max-width": {
          "type": "string",
          "pattern": "^[0-9]+(px|%)$",
          "examples": ["300px", "60%"]
        },
        "is-mandatory": {
          "type": "boolean",
          "default": false,
          "examples": [true, false]
        }
      },
      "additionalProperties": false
    },
    "selection-action": {
      "type": "object",
      "required": ["event", "target-screen-id"],
      "properties": {
        "event": {
          "type": "string",
          "enum": ["click", "double-click"],
          "examples": ["click", "double-click"]
        },
        "target-screen-id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "examples": ["screen-employee-detail"]
        },
        "include-record-id": {
          "type": "boolean",
          "default": true,
          "examples": [true]
        }
      },
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "key": [],
      "sections": [
        {
          "name": "default-section",
          "layout-policy": "flow",
          "is-collapsible": false,
          "fields": [
            {
              "id": "calc-001",
              "name": "First Number",
              "description": "Type first number to add",
              "type": "Integer",
              "width": "300px"
            }
          ]
        }
      ]
    }
  ],
  "additionalProperties": false
}