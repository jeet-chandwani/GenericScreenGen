{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genericscreengen.local/schemas/screen-config.schema.json",
  "title": "Generic Screen Configuration",
  "description": "Schema for dynamic screen configuration files used by GenericScreenGenApp.",
  "type": "object",
  "required": ["sections"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Optional screen identifier. When omitted, defaults to file name without 'Screen-' prefix and '.json' suffix.",
      "examples": ["employee-list", "calculator"]
    },
    "name": {
      "type": "string",
      "description": "Optional display name for the screen. When omitted, defaults to file name without 'Screen-' prefix and '.json' suffix.",
      "examples": ["Employee List", "Calculator"]
    },
    "features": {
      "type": "array",
      "description": "Optional screen-level feature toggles.",
      "items": {
        "type": "string",
        "enum": ["save", "cancel", "show-original-values"]
      },
      "examples": [["save", "cancel", "show-original-values"], ["cancel"]]
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/section"
      }
    }
  },
  "$defs": {
    "section": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "examples": ["default-section", "math-operations"]
        },
        "layout-policy": {
          "type": "string",
          "default": "per-line",
          "description": "Controls how fields inside this section are arranged. Built-in values: 'per-line' (each field on its own line, vertical stack), 'flow' (fields flow left-to-right with wrap), and 'tabular' (fields are rendered as table columns with records as rows). New policies can be added by implementing ILayoutPolicy and registering the implementation in the dependency-injection container — no schema change required.",
          "examples": ["per-line", "flow", "tabular"]
        },
        "is-collapsible": {
          "type": "boolean",
          "default": true,
          "examples": [true, false]
        },
        "detail-screen": {
          "type": "string",
          "description": "Optional target screen file name for row-click navigation in tabular sections.",
          "examples": ["Screen-Employee-Detail.json"]
        },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/field"
          }
        },
        "sections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/section"
          }
        }
      },
      "additionalProperties": false
    },
    "field": {
      "type": "object",
      "required": ["id", "name", "description", "type", "width"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "examples": ["calc-001", "ord-002"]
        },
        "name": {
          "type": "string",
          "examples": ["First Number", "Calculate"]
        },
        "description": {
          "type": "string",
          "examples": ["Type first number to add", "Click to compute the result"]
        },
        "type": {
          "type": "string",
          "enum": ["Integer", "Button", "Text", "Date", "DateTime", "Date-Time", "Lookup", "date", "date-time", "lookup", "text"],
          "examples": ["Integer", "Button", "Date", "date-time", "Lookup"]
        },
        "type-info": {
          "type": "string",
          "description": "Optional type-specific configuration. Text format: {min-chars=0;max-chars=10;lines=1;} Lookup format: {value 1;value 2;value 3}",
          "examples": ["{min-chars=0;max-chars=10;lines=1;}", "{Pending;Approved;Rejected}"]
        },
        "width": {
          "type": "string",
          "pattern": "^[0-9]+px$",
          "examples": ["300px", "200px"]
        },
        "max-width": {
          "type": "string",
          "pattern": "^[0-9]+(px|%)$",
          "examples": ["300px", "60%"]
        },
        "is-mandatory": {
          "type": "boolean",
          "default": false,
          "examples": [true, false]
        }
      },
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "sections": [
        {
          "name": "default-section",
          "layout-policy": "flow",
          "is-collapsible": false,
          "fields": [
            {
              "id": "calc-001",
              "name": "First Number",
              "description": "Type first number to add",
              "type": "Integer",
              "width": "300px"
            }
          ]
        }
      ]
    }
  ],
  "additionalProperties": false
}