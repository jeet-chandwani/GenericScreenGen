{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Data Store Config",
  "type": "object",
  "required": ["id", "name", "provider-type", "parameters"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "provider-type": {
      "type": "string",
      "enum": ["json", "sql-server"]
    },
    "parameters": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}
