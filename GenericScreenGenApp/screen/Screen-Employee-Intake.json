{
  "id": "screen-employee-intake",
  "name": "Employee Intake",
  "key": [],
  "theme": "vivid-gradient",
  "features": [ ],
  "sections": [
    {
      "name": "default-section",
      "layout-policy": "per-line",
      "is-collapsible": false,
      "fields": [
        {
          "id": "emp-001",
          "name": "Employee Name",
          "description": "Enter the full name of the employee",
          "type": "Text",
          "type-info": "{min-chars=0;max-chars=60;lines=1;}",
          "width": "340px"
        },
        {
          "id": "emp-002",
          "name": "Employee Id",
          "description": "Enter the internal employee identifier",
          "type": "Text",
          "type-info": "{min-chars=1;max-chars=20;lines=1;}",
          "width": "180px"
        },
        {
          "id": "emp-005",
          "name": "Start Date",
          "description": "Select the employee start date",
          "type": "Date",
          "width": "150px"
        },
        {
          "id": "emp-006",
          "name": "Last Review Meeting",
          "description": "Select date and time for the last review",
          "type": "date-time",
          "width": "200px"
        },
        {
          "id": "emp-007",
          "name": "Department",
          "description": "Select the employee department",
          "type": "Lookup",
          "type-info": "{Engineering;Operations;Human Resources;Finance}",
          "width": "200px"
        }
      ],
      "sections": [
        {
          "name": "contact-details",
          "layout-policy": "flow",
          "is-collapsible": true,
          "fields": [
            {
              "id": "emp-003",
              "name": "Phone Number",
              "description": "Enter the employee contact number",
              "type": "Text",
              "type-info": "{min-chars=0;max-chars=14;lines=1;}",
              "width": "260px"
            },
            {
              "id": "emp-004",
              "name": "Email Address",
              "description": "Enter the employee email address",
              "type": "Text",
              "type-info": "{min-chars=0;max-chars=50;lines=1;}",
              "width": "260px"
            },
            {
              "id": "emp-005",
              "name": "Save Employee",
              "description": "Persist the employee details",
              "type": "Button",
              "width": "180px"
            }
          ]
        }
      ]
    }
  ]
}